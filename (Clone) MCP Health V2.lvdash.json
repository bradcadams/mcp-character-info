{
  "datasets": [
    {
      "name": "87a74e83",
      "displayName": "characters",
      "config": {
        "source": "mcp.game.characters",
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          },
          {
            "displayName": "Average Health - Front",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              },
              "abbreviation": "none",
              "hideGroupSeparator": false
            },
            "name": "Average Health - Front",
            "expr": "AVG(source.front_health)",
            "comment": "Average health on the front side of the card."
          },
          {
            "displayName": "Average Health - Back",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              },
              "abbreviation": "none",
              "hideGroupSeparator": false
            },
            "name": "Average Health - Back",
            "expr": "AVG(source.back_health)",
            "comment": "Average health on the back side of the card."
          },
          {
            "displayName": "Average Health",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              },
              "abbreviation": "none",
              "hideGroupSeparator": false
            },
            "name": "Average Health",
            "expr": "AVG(`Total Health`)",
            "comment": "Average total health for characters."
          },
          {
            "displayName": "Average Threat",
            "format": {
              "type": "number",
              "decimalPlaces": {
                "type": "exact",
                "places": 2.0
              },
              "abbreviation": "none",
              "hideGroupSeparator": false
            },
            "name": "Average Threat",
            "expr": "AVG(source.threat)",
            "comment": "Average threat of characters."
          }
        ],
        "version": "1.1",
        "dimensions": [
          {
            "name": "character_id",
            "expr": "source.character_id",
            "comment": "Unique identifier for the character. Should match the MTC code from Cerebro and Jarvis.",
            "displayName": "Character Id"
          },
          {
            "name": "charcter_name",
            "expr": "source.charcter_name",
            "comment": "Name of the character on the card.",
            "displayName": "Charcter Name"
          },
          {
            "name": "alter_ego",
            "expr": "source.alter_ego",
            "comment": "Name of the charcter's alter ego",
            "displayName": "Alter Ego"
          },
          {
            "name": "threat",
            "expr": "source.threat",
            "comment": "The *threat* cost of the character.",
            "displayName": "Threat"
          },
          {
            "name": "front_health",
            "expr": "source.front_health",
            "comment": "Health on the front (healthy) side of the character card.",
            "displayName": "Front Health"
          },
          {
            "name": "back_health",
            "expr": "source.back_health",
            "comment": "Health on the back (injured) side of the character card.",
            "displayName": "Back Health"
          },
          {
            "name": "extra_power",
            "expr": "source.extra_power",
            "comment": "Additional power this charcter received in the power phase.",
            "displayName": "Extra Power"
          },
          {
            "name": "leadership_affiliation_id",
            "expr": "source.leadership_affiliation_id",
            "comment": "ID of the affilaition this charcter this character leads.",
            "displayName": "Leadership Affiliation Id"
          },
          {
            "name": "leadership_card_id",
            "expr": "source.leadership_card_id",
            "comment": "ID for the team tactics cards required for this charcter to have a leadership.",
            "displayName": "Leadership Card Id"
          },
          {
            "name": "gem_bearer",
            "expr": "source.gem_bearer",
            "comment": "Indicates if the character can be assigned an Infinity Gem.",
            "displayName": "Gem Bearer"
          },
          {
            "name": "gem_limit",
            "expr": "source.gem_limit",
            "comment": "The maximum number of infinity games that can be assigned to this character.",
            "displayName": "Gem Limit"
          },
          {
            "name": "Total Health",
            "expr": "COALESCE(front_health,0)+COALESCE(back_health,0)",
            "comment": "Combined health of the character.",
            "displayName": "Total Health"
          },
          {
            "name": "update_key",
            "expr": "character_updates.update_key",
            "comment": "Unique key for the update, usually the calendar year and month in YYYYMM format."
          },
          {
            "name": "effective_date",
            "expr": "character_updates.amg_updates.effective_date",
            "comment": "Approximate date when the update was released/effective.",
            "displayName": "Character Update"
          },
          {
            "name": "affiliation_name",
            "expr": "affiliated_charcters.affiliation_name",
            "comment": "Name of the affiliation.",
            "displayName": "Affiliation"
          }
        ],
        "joins": [
          {
            "name": "affiliated_charcters",
            "source": "mcp.game.affiliated_charcters",
            "on": "source.character_id = affiliated_charcters.character_id"
          }
        ]
      }
    }
  ],
  "pages": [
